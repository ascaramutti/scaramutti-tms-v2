# Template de variables de entorno del backend. Unico .env* que se commitea.
#
# TODAS las variables son OBLIGATORIAS — application.properties no tiene defaults.
# Si falta alguna, Quarkus no arranca y avisa cual.
#
# Setup local (cada dev):
#   1. cp .env.example .env
#   2. Completar todos los valores (ver ejemplos abajo)
#   3. mvn quarkus:dev
#
# En produccion: definir como env vars reales del sistema (NO commitear secretos).
# Quarkus prioriza env vars del SO sobre el archivo `.env`.

# --- DB ---------------------------------------------------------------------
# Credenciales y URL de la BD. Ejemplo dev: scaramutti_user / dev_local_only
# apuntando a localhost:5432/scaramutti_tms_dev.
DB_USERNAME=
DB_PASSWORD=
DB_JDBC_URL=

# --- CORS -------------------------------------------------------------------
# URL del frontend (sin trailing slash). Ejemplo dev: http://localhost:5173
CORS_ORIGINS=

# --- JWT keys ---------------------------------------------------------------
# Path a los archivos PEM. En prod montar como secret/volume.
# Ejemplo dev: keys/publickey.pem  |  keys/privatekey.pem
JWT_PUBLIC_KEY_LOCATION=
JWT_PRIVATE_KEY_LOCATION=

# --- Token lifespans (segundos) ---------------------------------------------
# Ejemplo dev: 3600 (1h access) | 86400 (24h refresh)
ACCESS_TOKEN_LIFESPAN_SECONDS=
REFRESH_TOKEN_LIFESPAN_SECONDS=
