# Template de variables de entorno del frontend. Unico .env* que se commitea.
#
# Setup local (cada dev):
#   1. Copiar este archivo: `cp .env.example .env.local`
#   2. Completar VITE_API_BASE_URL con el URL del backend (ver ejemplos abajo)
#   3. Ejecutar `npm run dev`
#
# Vite expone al cliente UNICAMENTE las variables prefijadas con `VITE_`.
# Vite carga `.env*` con esta precedencia (mayor a menor):
#   1. `.env.<mode>.local`  (override por maquina, gitignored)
#   2. `.env.<mode>`        (gitignored — usar para defaults por modo en tu maquina)
#   3. `.env.local`         (override por maquina, gitignored)
#   4. `.env`               (gitignored — defaults compartidos en tu maquina)
# El unico .env* committed es este `.env.example`.

# URL base del backend (sin trailing slash). Obligatoria.
# Ejemplos: http://localhost:8080/api/v1  |  https://api.tu-dominio.com/api/v1
VITE_API_BASE_URL=
